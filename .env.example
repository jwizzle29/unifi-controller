# Copy to .env and edit before running ./deploy.sh.

# UID/GID the controller process runs as (linuxserver convention).
# Owns /srv/unifi/data on the host.
PUID=1000
PGID=1000

# Timezone for log timestamps and scheduled tasks.
TZ=America/New_York

# Auto-generated by deploy.sh on first run; do not edit by hand.
# MONGO_PASS=
